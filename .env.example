# .env.example - copy to .env and fill in your values
# NEVER commit .env to git

# ── Option A: AWS Bedrock (recommended) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-haiku-4-5-20251001

# ── Option B: Direct Anthropic API (fallback) ─────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Promptfoo eval keys (project-scoped) ─────────────────────────────────────
# Used by promptfoo/providers/aura_provider.py
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional: only needed for redteam-compare-eval.yaml OpenAI lane
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=o4-mini
PROMPTFOO_API_KEY=pf-...

# Optional eval overrides (defaults shown)
AURA_EVAL_LLM_PROVIDER=anthropic
AURA_EVAL_LLM_MODEL=claude-haiku-4-5-20251001

# -- Hybrid RAG knowledge source controls & chunking ----------------------------
KB_USE_SEED=true
KB_ENABLE_CDC=false
KB_ENABLE_PUBMED=false
KB_ENABLE_OPENFDA=false
KB_ENABLE_OPENFDA_EVENT=false
KB_ENABLE_OPENFDA_ZIP=false

# RAG chunking settings for improved retrieval precision
# Smaller chunks improve semantic match for symptom-specific retrieval patterns.
# Default: 900 chars/chunk with 150 chars overlap balances retrieval quality vs compute cost.
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
# Tuning guide:
#   - Increase chunk_size (900→1200) for longer document context, but reduces precision for FAQ-style KB
#   - Decrease chunk_size (900→600) for shorter, focused chunks; improves RAG hit rate for symptom queries
#   - Increase overlap (150→250) to smooth boundaries; reduces chance of splitting key concepts
#   - Decrease overlap (150→50) to save compute; suitable if KB has clear section breaks

# Singapore guideline pages (comma-separated URLs, free/no key)
# Note: variable name remains CDC_GUIDELINE_URLS for compatibility with Cell 6 code.
CDC_GUIDELINE_URLS=https://www.moh.gov.sg/hpp/all-healthcare-professionals/guidelines,https://www.moh.gov.sg/newsroom,https://www.lia.org.sg

# PubMed E-utilities (free; API key optional for higher limits)
# Query aligned to Singapore 37 Critical Illness definitions.
PUBMED_QUERY=(major cancer OR heart attack OR myocardial infarction OR coronary artery bypass OR stroke with neurological deficit OR end stage kidney failure OR coma OR irreversible paralysis OR open heart valve surgery OR irreversible blindness OR irreversible deafness OR irreversible loss of speech OR multiple sclerosis OR fulminant hepatitis OR major organ transplant OR bone marrow transplantation OR primary pulmonary hypertension OR severe dementia OR alzheimer disease OR surgery to aorta OR major burns OR terminal illness OR HIV due to blood transfusion OR occupationally acquired HIV OR end stage lung disease OR end stage liver failure OR muscular dystrophy OR idiopathic parkinson disease OR irreversible aplastic anaemia OR angioplasty OR invasive treatment for coronary artery OR severe bacterial meningitis OR benign brain tumour OR severe encephalitis OR motor neurone disease OR persistent vegetative state OR loss of independent existence OR major head trauma OR serious coronary artery disease OR poliomyelitis OR progressive scleroderma OR systemic lupus erythematosus lupus nephritis) AND (guideline OR consensus OR clinical practice guideline)
PUBMED_RETMAX=30
PUBMED_EMAIL=you@example.com
PUBMED_TOOL=aura-health-rag
NCBI_API_KEY=

# openFDA drug label API (free; key optional)
OPENFDA_TERMS=lisinopril,losartan,amlodipine,hydrochlorothiazide,metformin,empagliflozin,sitagliptin,insulin glargine,atorvastatin,aspirin,clopidogrel,acetaminophen,ibuprofen,naproxen,omeprazole,albuterol,budesonide,amoxicillin,azithromycin,cetirizine
OPENFDA_API_KEY=
OPENFDA_EVENT_TERMS=lisinopril,metformin,ibuprofen
OPENFDA_EVENT_PER_TERM_LIMIT=5
OPENFDA_ZIP_DIR=data/fda_zip_drop
OPENFDA_ZIP_MAX_DOCS=200

# Optional Hugging Face Inference settings for medical LLM experiments
HF_API_TOKEN=hf_...
HF_MEDICAL_MODEL=m42-health/Llama3-Med42-8B

# Optional STT defaults (Cell 10a mic mode + Cell 10b smoke mode)
# Set true to auto-enable microphone capture in Cell 10a.
USE_STT_MIC_DEFAULT=false

# OpenAI STT model and recording controls used by Cell 10a.
# Primary default intentionally set to gpt-4o-mini.
STT_OPENAI_MODEL=gpt-4o-mini
# If primary model is unavailable for transcription, try these in order.
STT_OPENAI_FALLBACK_MODELS=gpt-4o-mini-transcribe,whisper-1
STT_LANGUAGE=en
STT_SAMPLE_RATE=16000
STT_CHUNK_SECONDS=8
STT_NUM_CHUNKS=3
# End early when spoken keyword is detected in a chunk transcript.
STT_ENABLE_VOICE_STOP=true
STT_VOICE_STOP_KEYWORDS=stop recording,end transcript,stop

# Cell 10b controls this in-notebook by default; keep false in .env unless needed.
STT_SMOKE_TEST=false
