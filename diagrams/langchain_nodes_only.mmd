flowchart TD
    START([START]) --> stt_prep["STT prep<br/>Transcript normalisation"]
    stt_prep --> intake["Intake agent<br/>PII scrub + patient context"]
    intake --> supervisor["Supervisor router<br/>Conditional agent dispatch"]

    supervisor --> clinical["Clinical agent<br/>Guideline / CDC RAG"]
    supervisor --> drug["Drug agent<br/>Medication safety review"]
    supervisor --> research["Research agent<br/>PubMed evidence retrieval"]

    clinical --> summary["Summary agent<br/>Synthesis + SOAP note"]
    drug --> summary
    research --> summary

    summary --> output["Output node<br/>API / dashboard response"]
    output --> END([END])

    subgraph TOOLS["LangChain tools / retrievers / model"]
        faiss["FAISS guideline retriever"]
        fda["FDA / drug context retriever"]
        pubmed["PubMed evidence retriever"]
        presidio["Presidio PII scrubber"]
        bedrock["AWS Bedrock Claude"]
    end

    intake -. uses .-> presidio
    supervisor -. routes with .-> bedrock
    clinical -. retrieves .-> faiss
    clinical -. prompts .-> bedrock
    drug -. retrieves .-> fda
    drug -. prompts .-> bedrock
    research -. retrieves .-> pubmed
    research -. prompts .-> bedrock
    summary -. synthesises with .-> bedrock

